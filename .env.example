# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# EveryPay
EVERYPAY_API_USERNAME=your-api-username
EVERYPAY_API_SECRET=your-api-secret
EVERYPAY_API_URL=https://igw-demo.every-pay.com/api/v4
EVERYPAY_ACCOUNT_NAME=EUR3D1

# Email
RESEND_API_KEY=re_your_key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Unisend Shipping
UNISEND_API_URL=https://api-manosiuntostst.post.lt
UNISEND_USERNAME=your-username
UNISEND_PASSWORD=your-password

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Server-only canonical origin for redirects behind reverse proxy (set in production, not needed locally)
# APP_ORIGIN=https://your-domain.com

# Sentry (optional — error monitoring)
# NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/your-project-id
# SENTRY_AUTH_TOKEN=your-auth-token
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project
